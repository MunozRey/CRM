# Propel — environment variables
# Copy to .env.local and fill from your Supabase project dashboard.
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser; everything else is
# server-only (Edge Functions, server actions, CI).

# ── Supabase (required) ───────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-only — never expose to the browser (Edge Functions, server actions)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Sentry browser DSN
# NEXT_PUBLIC_SENTRY_DSN=

# Optional: PostHog product analytics + Web Vitals (public key, EU region).
# Consent-gated: only loads/captures after the visitor accepts analytics in the
# cookie banner. Host defaults to https://eu.i.posthog.com when unset.
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── AI providers (Edge Functions, optional) ───────────────────────────────────
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Email — Resend (optional; enables campaign / sequence sending) ────────────
# Edge-function secrets. RESEND_FROM must be an address on a domain you've verified
# in Resend (SPF+DKIM), e.g. "Propel <hello@propeltech.es>". RESEND_WEBHOOK_SECRET
# verifies Resend bounce/complaint webhooks (accept-and-log until it's set).
# RESEND_API_KEY=
# RESEND_FROM=
# RESEND_WEBHOOK_SECRET=

# ── Google OAuth — Gmail / Calendar (optional) ────────────────────────────────
# Redirect URI to register in the Google Cloud console: {origin}/auth/gmail/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# AES-256-GCM key encrypting the stored Google refresh token at rest.
# Optional — falls back to SUPABASE_SERVICE_ROLE_KEY when unset.
# Generate with: openssl rand -hex 32
# GOOGLE_TOKEN_ENC_KEY=

# ── Stripe billing (optional) ─────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── Other connector secrets (optional) ────────────────────────────────────────
# AES-256-GCM key encrypting Slack webhook URLs / Zoom webhook secrets at rest.
# Optional — falls back to SUPABASE_SERVICE_ROLE_KEY when unset.
# Generate with: openssl rand -hex 32
# INTEGRATION_TOKEN_ENC_KEY=
#
# Outbound webhook subscriptions (Settings → Integrations → Webhooks — used by
# n8n, Zapier, or any HTTP endpoint) are signed per-subscription: the signing
# secret is generated server-side when you create a subscription and shown
# once — there is no global env var to set for this.
